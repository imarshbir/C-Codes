#include<stdio.h>
struct students {
    char name[50];
    int roll;
    float marks;
};

int main(){
    
    struct students s[3];
    
    for(int i=0;i<3;i++){
        printf("Enter name, roll and marks:\n");
        scanf("%s %d %f", s[i].name,&s[i].roll, &s[i].marks);
    }
    
    for(int i=0;i<3;i++){
        printf("Enter %d name, roll and marks:", i+1);
        printf("%s,%d, %.2f  \n", 
        s[i].name,s[i].roll,s[i].marks);
    }
}